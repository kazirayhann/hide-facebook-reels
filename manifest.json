{
  "manifest_version": 3,
  "name": "Hide Facebook Reels",
  "version": "1.0.0",
  "description": "Hides Facebook Reels feed sections, blocks Reels pages, and removes Sponsored sidebar sections on facebook.com.",
  "permissions": [
    "tabs",
    "webNavigation"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "https://www.facebook.com/*",
        "https://facebook.com/*"
      ],
      "css": [
        "styles.css"
      ],
      "js": [
        "redirect-config.js",
        "content.js"
      ],
      "run_at": "document_start"
    }
  ]
}
